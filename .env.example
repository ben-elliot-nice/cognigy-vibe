# Copy this file to .env and fill in your values.
# Run `mise trust` once per clone so mise auto-sources this file on directory entry.

COGNIGY_BASE_URL=https://cognigy-api-au1.nicecxone.com
COGNIGY_API_KEY=your-api-key-here
COGNIGY_PROJECT_ID=your-project-id-here

# Optional — tune server behaviour
# COGNIGY_VIBE_RESYNC_HOURS=4
# COGNIGY_VIBE_CACHE_TTL=300

# Dev mode — spawn MCP server from local source instead of the published package.
# Requires credentials above to be configured first.
# COGNIGY_VIBE_DEV=1
# COGNIGY_VIBE_SOURCE_DIR=/absolute/path/to/cognigy-claude-plugin/cognigy-mcp
